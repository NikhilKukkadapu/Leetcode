class Solution {
    public int countPrimes(int n) {
        if (n <= 2) {
            return 0;
        }
        
        // false means prime, true means composite (not prime)
        // Default values in a boolean array in Java are false
        boolean[] notPrime = new boolean[n];
        int primeCount = 0;
        
        // Loop up to the square root of n
        for (int i = 2; i * i < n; i++) {
            // If i is prime, mark its multiples as composite
            if (!notPrime[i]) {
                for (int j = i * i; j < n; j += i) {
                    notPrime[j] = true;
                }
            }
        }
        
        // Count the numbers that are still marked as prime (false)
        for (int i = 2; i < n; i++) {
            if (!notPrime[i]) {
                primeCount++;
            }
        }
        
        return primeCount;
    }
}
