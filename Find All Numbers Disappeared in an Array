class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        List<Integer> result = new ArrayList<>();
        Set<Integer> set = new HashSet<>();
        
        // Step 1: Add all numbers to the hash set
        for (int num : nums) {
            set.add(num);
        }
        
        // Step 2: Check for missing numbers in the range [1, n]
        for (int i = 1; i <= nums.length; i++) {
            if (!set.contains(i)) {
                result.add(i);
            }
        }
        
        return result;
    }
}
