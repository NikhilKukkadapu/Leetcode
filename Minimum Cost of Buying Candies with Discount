class Solution {
    public int minimumCost(int[] cost) {
       Arrays.sort(cost);

        int total = 0;
        int n = cost.length;

        // Traverse from highest cost to lowest
        for (int i = n - 1, count = 1; i >= 0; i--, count++) {
            if (count % 3 != 0) { // Every 3rd candy is free
                total += cost[i];
            }
        }

        return total; 
    }
}
