class Solution {
    public int peakElement(int[] arr) {
        // code here
        int n = arr.length;
        int low = 0;
        int high = n - 1;

        while (low < high) {
            int mid = low + (high - low) / 2;

            // If the element to the right is larger, a peak must lie on the right side
            if (arr[mid] < arr[mid + 1]) {
                low = mid + 1;
            } 
            // Otherwise, a peak must lie on the left side (including mid)
            else {
                high = mid;
            }
        }
        
        // low and high converge to a peak element index
        return low;
    }
}
