class Solution {
    public boolean isAnagram(String s, String t) {
         // Lengths must be same
        if(s.length() != t.length()) {
            return false;
        }

        int[] count = new int[26];

        // Count characters from s
        for(int i = 0; i < s.length(); i++) {

            count[s.charAt(i) - 'a']++;

            count[t.charAt(i) - 'a']--;
        }

        // Check all frequencies become 0
        for(int num : count) {

            if(num != 0) {
                return false;
            }
        }

        return true;
    }
}
